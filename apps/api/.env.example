# Aiven MySQL connection string. Aiven requires SSL - Prisma handles this via
# the sslaccept param since Aiven's CA is publicly trusted; if you hit SSL
# errors, download the CA cert from the Aiven console and set sslcert=/path/to/ca.pem
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DBNAME?sslaccept=strict"

JWT_SECRET="change-this-to-a-long-random-string"

PORT=4000
